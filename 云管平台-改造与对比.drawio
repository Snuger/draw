        <mxCell id="1GPVzzzuzYTmp76btM8G-57" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontColor=#FF3333;" value="集成部署，依赖，产品，租户" vertex="1">
